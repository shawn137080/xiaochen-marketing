# AI 优化 (OpenAI 兼容接口，必填)
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://aiberm.com/v1
LLM_MODEL=google/gemini-3-flash

# 数据库路径 (Docker 环境自动设置，本地可留空)
# XHS_DB_PATH=/data/xhs.db

# 图片目录 (Docker 环境自动设置，本地可留空)
# XHS_IMAGES_DIR=/data/images

# MCP 服务地址 (Docker 内部自动设置)
# XHS_MCP_URL=http://localhost:18060
